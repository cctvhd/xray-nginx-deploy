{
  "log": {
    "level":     "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag":         "warp-dns",
        "type":        "udp",
        "server":      "1.1.1.1",
        "server_port": 53,
        "detour":      "warp"
      },
      {
        "tag":  "local_recursive",
        "type": "local"
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-cn"],
        "server":   "warp-dns"
      }
    ],
    "final":           "local_recursive",
    "strategy":        "prefer_ipv4",
    "reverse_mapping": true
  },
  "inbounds": [
    {
      "type":        "anytls",
      "tag":         "anytls-in",
      "listen":      "127.0.0.1",
      "listen_port": 8443,
      "users": [
        {
          "password": "6rAS03lKxhYnJRwd1Hcb-2e21be83"
        }
      ],
      "padding_scheme": [
        "stop=8",
        "0=100-300",
        "1=300-600",
        "2=600-1200",
        "3=200-500,c",
        "4=400-900",
        "5=100-400,600-1000,c",
        "6=200-600,800-1400",
        "7=300-800,1000-1600,c"
      ],
      "tls": {
        "enabled":          true,
        "server_name":      "la.ccpv.tk",
        "certificate_path": "/etc/letsencrypt/live/ccpv.tk/fullchain.pem",
        "key_path":         "/etc/letsencrypt/live/ccpv.tk/privkey.pem",
        "alpn":             ["h2", "http/1.1"],
        "min_version":      "1.3",
        "max_version":      "1.3"
      }
    }
  ],
  "endpoints": [
        {
      "type":        "wireguard",
      "tag":         "warp",
      "address":     ["172.16.0.2/32","2606:4700:110:8529:1a10:13d1:aa2f:5ad5/128"],
      "private_key": "kJATOBFMkz4OgkUOpOFVJkhzDo4/IkeZ4NCCz+1dWVA=",
      "peers": [
        {
          "address":     "engage.cloudflareclient.com",
          "port":        2408,
          "public_key":  "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=",
          "reserved":    [0, 0, 0],
          "allowed_ips": ["0.0.0.0/0", "::/0"]
        }
      ],
      "mtu": 1280
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag":  "direct"
    },
    {
      "type": "block",
      "tag":  "block"
    }
  ],
  "route": {
    "auto_detect_interface":  true,
    "default_domain_resolver": "local_recursive",
    "rule_set": [
      {
        "tag":             "geosite-cn",
        "type":            "remote",
        "format":          "binary",
        "url":             "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/cn.srs",
        "update_interval": "1d"
      },
      {
        "tag":             "geoip-cn",
        "type":            "remote",
        "format":          "binary",
        "url":             "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/cn.srs",
        "update_interval": "1d"
      }
    ],
    "rules": [
      {
        "action":  "sniff",
        "sniffer": ["dns", "http", "tls", "quic"],
        "timeout": "300ms"
      },
      {
        "protocol": "dns",
        "action":   "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action":        "reject"
      },
      {
        "rule_set": ["geosite-cn"],
        "outbound": "warp"
      },
      {
        "rule_set": ["geoip-cn"],
        "outbound": "warp"
      }
    ],
    "final": "direct"
  },
  "experimental": {
    "cache_file": {
      "enabled":     true,
      "path":        "/var/lib/sing-box/cache.db",
      "store_fakeip": false
    }
  }
}
