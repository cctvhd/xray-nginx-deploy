{
    "log": {
        "loglevel": "warn",
        "access":   "none",
        "error":    "/var/log/xray/error.log"
    },

    "dns": {
        "servers": [
            {
                "tag":      "local-dns",
                "address":  "localhost",
                "port":     53,
                "domains":  [
                    "geosite:geolocation-!cn",
                    "geosite:google",
                    "geosite:github",
                    "geosite:cloudflare",
                    "geosite:netflix",
                    "geosite:openai"
                ],
                "expectIPs":    ["geoip:!cn"],
                "skipFallback": true
            },
            {
                "tag":      "warp-dns",
                "address":  "1.1.1.1",
                "domains":  [
                    "geosite:cn",
                    "geosite:tld-cn"
                ],
                "expectIPs": ["geoip:cn"],
                "proxyTag":  "warp"
            }
        ],
        "disableCache":    false,
        "disableFallback": true,
        "queryStrategy":   "UseIPv4v6"
    },

    "routing": {
        "domainStrategy": "IPIfNonMatch",
        "rules": [
            {
                "type":        "field",
                "ip":          ["geoip:private"],
                "outboundTag": "block"
            },
            {
                "type":        "field",
                "domain":      ["geosite:cn", "geosite:tld-cn"],
                "outboundTag": "warp"
            },
            {
                "type":        "field",
                "ip":          ["geoip:cn"],
                "outboundTag": "warp"
            }
        ]
    },

    "inbounds": [
        {
            "tag":      "vless-xhttp-cdn",
            "listen":   "127.0.0.1",
            "port":     8001,
            "protocol": "vless",
            "settings": {
                "clients":     [{"id": "94832c11-9f9b-4197-a796-ecac49a77fac"}],
                "decryption":  "none"
            },
            "streamSettings": {
                "network":  "xhttp",
                "security": "none",
                "xhttpSettings": {
                    "path": "/c028cb9083544ea3ae6d62fc505c5251",
                    "host": "dn.zhongning.tk",
                    "extra": {
                        "enc":           "packet",
                        "xPaddingBytes": "100-1000",
                        "headers":       {"User-Agent": "chrome"},
                        "xmux": {
                            "maxConcurrency":   "4-8",
                            "maxConnections":   0,
                            "cMaxReuseTimes":   150,
                            "hMaxRequestTimes": "150-300",
                            "hMaxReusableSecs": "1800-3600",
                            "hKeepAlivePeriod": 60
                        }
                    }
                },
                "sockopt": {
                    "trustedXForwardedFor": ["127.0.0.1", "::1"]
                }
            },
            "sniffing": {
                "enabled":      true,
                "destOverride": ["http", "tls", "quic"],
                "metadataOnly": false
            }
        },

        {
            "tag":      "vless-grpc-cdn",
            "listen":   "127.0.0.1",
            "port":     8002,
            "protocol": "vless",
            "settings": {
                "clients":    [{"id": "94832c11-9f9b-4197-a796-ecac49a77fac"}],
                "decryption": "none"
            },
            "streamSettings": {
                "network":  "grpc",
                "security": "none",
                "grpcSettings": {
                    "serviceName":          "grpc.Service",
                    "multiMode":            true,
                    "idle_timeout":         80,
                    "health_check_timeout": 20
                }
            },
            "sniffing": {
                "enabled":      true,
                "destOverride": ["http", "tls", "quic"],
                "metadataOnly": false
            }
        },

        {
            "tag":      "reality-direct",
            "listen":   "127.0.0.1",
            "port":     9443,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id":   "94832c11-9f9b-4197-a796-ecac49a77fac",
                        "flow": "xtls-rprx-vision"
                    }
                ],
                "decryption": "none",
                "fallbacks":  [
                    {
                        "dest": "127.0.0.1:10080",
                        "xver": 0
                    }
                ]
            },
            "streamSettings": {
                "network":  "tcp",
                "security": "reality",
                "realitySettings": {
                    "show":        false,
                    "dest":        "www.siliconvalley.com:443",
                    "xver":        0,
                    "serverNames": ["la.zhongning.tk","www.siliconvalley.com","solanolibrary.com","www.oxy.edu","business.ca.gov"],
                    "privateKey":  "oLfAnST4louxVq1-pG5ZCNryZPGIfzQGC_g8LpGUbFI",
                    "shortIds":    ["7a5a0d2e","e9d281e6","dd16d0a3","24f191da4556","ec316b793239a7e4"],
                    "spiderX":     "/api/health"
                },
                "sockopt": {
                    "acceptProxyProtocol": true,
                    "tcpUserTimeout":       30000,
                    "tcpKeepAliveIdle":     300,
                    "tcpKeepAliveInterval": 30
                }
            },
            "sniffing": {
                "enabled":      true,
                "destOverride": ["http", "tls", "quic"],
                "metadataOnly": false
            }
        }
    ],

    "outbounds": [
        {
            "tag":      "direct",
            "protocol": "freedom",
            "settings": {
                "domainStrategy": "ForceIPv4v6"
            },
            "streamSettings": {
                "sockopt": {
                    "tcpUserTimeout":       30000,
                    "tcpKeepAliveIdle":     300,
                    "tcpKeepAliveInterval": 30
                }
            }
        },
        {
            "tag":      "block",
            "protocol": "blackhole"
        },
                {
            "tag":      "warp",
            "protocol": "wireguard",
            "settings": {
                "secretKey": "2I7qMPoX0SJq53Gq0Dvbgoa/F6UAUjmmcjisUnu4j0c=",
                "address":   ["172.16.0.2/32","2606:4700:110:8de9:94de:37ee:b0aa:31a8/128"],
                "peers": [
                    {
                        "publicKey":  "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=",
                        "endpoint":   "engage.cloudflareclient.com:2408",
                        "allowedIPs": ["::/0", "0.0.0.0/0"]
                    }
                ],
                "mtu":            1280,
                "domainStrategy": "ForceIPv4v6"
            }
        }
    ]
}
